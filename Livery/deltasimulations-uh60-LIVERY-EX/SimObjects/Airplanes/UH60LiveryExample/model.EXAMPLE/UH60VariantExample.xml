<?xml version="1.0" encoding="utf-8" ?>
<ModelInfo>
	<LODS>
		<LOD minSize="0" ModelFile="..\..\UH60\model\UH60M_LOD00.gltf"/>
	</LODS>
	<Behaviors>
		<IncludeBase RelativeFile="..\..\UH60\model\UH60M.XML"/>
    <Include ModelBehaviorFile="Asobo\Exterior.xml" />
    <Include ModelBehaviorFile="Asobo\Generic\FX.xml" />
    <Include ModelBehaviorFile="Asobo\AircraftTypes\Rotorcrafts.xml" />
    <Include Path="DeltaSim-UH60\DeltaSim_Anim_Template.xml" />
    <Include Path="DeltaSim-UH60\DeltaSim_Variants_Template.xml" />
    <Include Path="DeltaSim-UH60\DeltaSim_FX_Template.xml" />
<!-- Variant configuration
 If set up correctly, this will allow you to configure the parts to exactly what you want.
 This is set up through visibility conditions, where 1 is showing the described part, and 0 is not
 If uncertain, deleting a definition/line will fallback the part to what it is on the base UH-60M
 These are initialized in DeltaSim_Variants_Template.xml

 !! only use 1 or 0s !!
 Users who do not have the livery installed will see the base UH-60M, 
 if they have the livery installed they should see the updated model

 This livery is set up for a UH-60M with the HIRSS, a hoist, and no countermeasures
-->
<Component ID="Variant_Configuration">
      <UseTemplate Name = "DELTASIM_Variants_Template"> 
        <!-- 
        These 3 are normally user-controlled through the EFB, 
         you have the option of forcing them hidden/visible by replacing with a 1 or 0 -->
        <EIBF_INSTALLED>                  (L:H60_EBF)      </EIBF_INSTALLED>                  
        <SKIS_INSTALLED>                  (L:H60_Skis)</SKIS_INSTALLED>                  
        <CPITDOORS_INSTALLED>             (L:H60_FrontDoorVis) ! </CPITDOORS_INSTALLED> 

        <!-- Avionics Bay Intake Design, only 0 for the HH-60W which uses a special duct -->
        <AVNCS_DEFAULT_INSTALLED>         1     </AVNCS_DEFAULT_INSTALLED>      
        <!-- Stock Tail antennas, hidden in HH60W, visible for everything else -->                       
        <Stock_Tail_Antenna_INSTALLED>    1     </Stock_Tail_Antenna_INSTALLED>
        <!-- Hoist Installed?-->                         
        <Hoist_INSTALLED>                 1     </Hoist_INSTALLED>        
        <!-- Tail Chaff/Flare Bucket Installed? Hide for civ liveries-->          
        <Tail_CM_INSTALLED>               0     </Tail_CM_INSTALLED>   
        <!-- Refueling Probe Installed?-->               
        <Fuel_Probe_INSTALLED>            0     </Fuel_Probe_INSTALLED>      
        <!-- FrontGear Chaff/Flare bucket Installed? Used on HH-60W -->            
        <MLG_CM_INSTALLED>                0     </MLG_CM_INSTALLED>      
        <!-- Top X-band Antennas Installed? On MH-60M and HRT-->            
        <FM_ANTENNA_INSTALLED>            0     </FM_ANTENNA_INSTALLED>  
        <!-- Base Missile Warning Sensors Installed? 0 = for MH-60M, Any civ liveries -->                
        <Stock_MWS_INSTALLED>             0     </Stock_MWS_INSTALLED>        
        <!-- Troop Bubble window installed? On HH-60M 1 = show-->          
        <Bubble_Window_INSTALLED>         0     </Bubble_Window_INSTALLED>
        <!-- Is the UES installed? 1 = UES, 0 = HIRSS -->        
        <UES_INSTALLED>                   0     </UES_INSTALLED>
        <!-- Specific variant parts -->
        <!-- MH-60M / 160th sensors, parts -->
        <MH60M_Parts_INSTALLED>           0     </MH60M_Parts_INSTALLED> 
        <!-- HH60M Flir -->     
        <HH60M_Flir_INSTALLED>            0     </HH60M_Flir_INSTALLED> 
        <!-- HH-60W Sensors, parts -->  
        <HH60W_Parts_INSTALLED>           0     </HH60W_Parts_INSTALLED>
        <!-- MH60M DAP Pylons -->      
        <DAP_PYLONS_INSTALLED>            0     </DAP_PYLONS_INSTALLED>          
      </UseTemplate>
</Component>
</Behaviors>
</ModelInfo>